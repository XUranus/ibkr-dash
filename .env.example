# =============================================================================
# IBKR Dash — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Each module (backend, worker) reads its own .env from its directory.
# The root .env is for reference; copy relevant sections to each module.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend (ibkr_dash_backend/.env)
# -----------------------------------------------------------------------------

# App
APP_ENV=development
DEBUG=true

# SQLite database path (relative to backend working directory)
SQLITE_PATH=data/ibkr_dash.db

# In-memory cache TTL in seconds (default: 24 hours)
CACHE_TTL_SECONDS=86400

# LLM Configuration (OpenAI-compatible API)
# Supports any OpenAI-compatible endpoint (OpenAI, Xiaomi MiMo, DeepSeek, etc.)
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_DEFAULT_MODEL=gpt-4o
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Authentication
# Leave AUTH_PASSWORD empty to disable login (open access)
AUTH_USERNAME=admin
AUTH_PASSWORD=

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# Worker (ibkr_dash_worker/.env)
# -----------------------------------------------------------------------------

# Data directory for IBKR Flex CSV exports
DATA_DIR=data/flex_exports

# Scheduler settings
SCHEDULER_ENABLED=true
SCHEDULER_HOUR=12
SCHEDULER_MINUTE=30
SCHEDULER_TIMEZONE=Asia/Shanghai

# Backend URL (for triggering reviews and emails after import)
BACKEND_BASE_URL=http://localhost:8000
DAILY_REVIEW_INTERNAL_TOKEN=

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# IBKR Flex Web Service (for automatic data pull)
# -----------------------------------------------------------------------------
# Get your token from: IBKR Account Management > Settings > Flex Web Service
FLEX_TOKEN=
FLEX_QUERY_ID_DAILY=
FLEX_BASE_URL=https://www.interactivebrokers.com/AccountManagement/FlexWebService
FLEX_POLL_INTERVAL_SECONDS=10
FLEX_MAX_POLL_RETRIES=60

# -----------------------------------------------------------------------------
# Longbridge (optional, for public market data in AI agents)
# -----------------------------------------------------------------------------
LONGBRIDGE_APP_KEY=
LONGBRIDGE_APP_SECRET=
LONGBRIDGE_ACCESS_TOKEN=
