# =============================================================================
# IBKR Dash — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real credentials.
# =============================================================================

# --- App ---
APP_ENV=development
DEBUG=true

# --- SQLite ---
# Path relative to each module's working directory (backend resolves to project root)
SQLITE_PATH=data/ibkr_dash.db

# --- Cache ---
CACHE_TTL_SECONDS=86400

# --- LLM (OpenAI-compatible API) ---
# Supports: OpenAI, Xiaomi MiMo, DeepSeek, Anthropic (via proxy), etc.
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_DEFAULT_MODEL=gpt-4o
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=8192

# --- Auth ---
# Leave AUTH_PASSWORD empty to disable login (open access)
AUTH_USERNAME=admin
AUTH_PASSWORD=

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- IBKR Flex Web Service ---
# Token from: IBKR Account Management > Settings > Flex Web Service
FLEX_TOKEN=
FLEX_BASE_URL=https://www.interactivebrokers.com/AccountManagement/FlexWebService
FLEX_POLL_INTERVAL_SECONDS=10
FLEX_MAX_POLL_RETRIES=60

# --- Worker ---
DATA_DIR=data/flex_exports
SCHEDULER_ENABLED=true
SCHEDULER_HOUR=12
SCHEDULER_MINUTE=30
SCHEDULER_TIMEZONE=Asia/Shanghai
BACKEND_BASE_URL=http://localhost:8000

# --- Logging ---
LOG_LEVEL=INFO

# --- Longbridge (optional, for public market data) ---
LONGBRIDGE_APP_KEY=
LONGBRIDGE_APP_SECRET=
LONGBRIDGE_ACCESS_TOKEN=
