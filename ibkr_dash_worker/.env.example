# IBKR Dash Worker Configuration
# Copy this file to .env and fill in your values.

# --- App ---
APP_ENV=development

# --- SQLite (shared with backend) ---
SQLITE_PATH=data/ibkr_dash.db

# --- Data directory for Flex CSV exports ---
DATA_DIR=data/flex_exports

# --- Scheduler ---
SCHEDULER_ENABLED=true
SCHEDULER_HOUR=12
SCHEDULER_MINUTE=30
SCHEDULER_TIMEZONE=Asia/Shanghai

# --- Logging ---
LOG_LEVEL=INFO

# --- Backend integration ---
BACKEND_BASE_URL=http://localhost:8000
DAILY_REVIEW_INTERNAL_TOKEN=

# --- IBKR Flex Web Service ---
FLEX_BASE_URL=https://www.interactivebrokers.com/AccountManagement/FlexWebService
FLEX_TOKEN=
FLEX_QUERY_ID_DAILY=
FLEX_POLL_INTERVAL_SECONDS=10
FLEX_MAX_POLL_RETRIES=60
