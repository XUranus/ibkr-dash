# =============================================================================
# IBKR Dash Backend — Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# =============================================================================

# App
APP_ENV=development
DEBUG=true

# SQLite database path (relative to backend working directory)
SQLITE_PATH=data/ibkr_dash.db

# In-memory cache TTL in seconds (default: 24 hours)
CACHE_TTL_SECONDS=86400

# LLM Configuration (OpenAI-compatible API)
# Supports: OpenAI, Xiaomi MiMo, DeepSeek, Anthropic (via proxy), etc.
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_DEFAULT_MODEL=gpt-4o
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Authentication
# Leave AUTH_PASSWORD empty to disable login (open access)
AUTH_USERNAME=admin
AUTH_PASSWORD=

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
